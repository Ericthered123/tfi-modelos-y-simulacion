# Plantilla de variables de entorno. Copiar a `.env` y completar con valores reales.
# El archivo `.env` está git-ignored: NUNCA se commitea el token.
#
#   cp .env.example .env    # Linux/Mac
#   copy .env.example .env  # Windows

# Token personal de la API de GitHub (scope: public_repo alcanza para lectura de un repo público).
# Generar en: https://github.com/settings/tokens
GITHUB_TOKEN=your_personal_access_token_here
